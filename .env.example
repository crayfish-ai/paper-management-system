# Papers directory (default: ./papers)
# PAPERMGR_PAPERS_DIR=/path/to/papers

# Downloads directory (default: ./downloads)
# PAPERMGR_DOWNLOADS_DIR=/path/to/downloads

# Database path (default: ./data/index.db)
# PAPERMGR_DATABASE_PATH=/path/to/data/index.db

# Enable AI summarization (default: false)
# PAPERMGR_AI_ENABLED=true

# OpenAI API Key (if using AI summarization)
# OPENAI_API_KEY=sk-...
